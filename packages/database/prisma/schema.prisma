// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  password      String?
  email         String         @unique
  emailVerified DateTime?      @unique @map("email_verified")
  image         String?
  avatarUrl     String?        @map("avatar_url")
  bio           String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          Role           @default(student)
  accounts      Account[]
  sessions      Session[]
  courses       Course[]
  enrollments   Enrollment[]
  payments      Payment[]
  reviews       Review[]
  forumPost     ForumPost[]
  comments      Comment[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  files         File[]
  auditLogs     AuditLog[]

  @@map("users")
}

enum Role {
  student
  instructor
  admin
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  courses Course[]

  @@map("categories")
}

model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  courseTags CourseTag[]

  @@map("tags")
}

model CourseTag {
  courseId String @map("course_id")
  tagId    String @map("tag_id")
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@index([tagId])
  @@map("course_tags")
}

model Course {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String        @db.Text
  thumbnail    String?
  price        Decimal       @default(0) @db.Decimal(10, 2)
  level        Level         @default(beginner)
  published    Boolean       @default(false)
  instructorId String        @map("instructor_id")
  instructor   User          @relation(fields: [instructorId], references: [id], onDelete: Restrict)
  categoryId   String        @map("category_id")
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lessons      Lesson[]
  enrollments  Enrollment[]
  payments     Payment[]
  reviews      Review[]
  forumPost    ForumPost[]
  chatMessages ChatMessage[]
  courseTags   CourseTag[]

  @@index([instructorId])
  @@index([categoryId])
  @@map("courses")
}

enum Level {
  beginner
  intermediate
  advanced
}

model Lesson {
  id               String           @id @default(cuid())
  title            String
  order            Int
  videoUrl         String?          @map("video_url")
  content          String?          @db.Text
  durationSec      Int?             @map("duration_sec")
  isFreePreview    Boolean          @default(false) @map("is_free_preview")
  courseId         String           @map("course_id")
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgresses LessonProgress[]
  comments         Comment[]

  @@unique([courseId, order])
  @@index([courseId])
  @@map("lessons")
}

model Enrollment {
  id               String           @id @default(cuid())
  enrolledAt       DateTime         @default(now())
  userId           String           @map("user_id")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String           @map("course_id")
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgresses LessonProgress[]

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("enrollments")
}

model LessonProgress {
  id              String     @id @default(cuid())
  completed       Boolean
  lastPositionSec Int        @map("last_position_sec")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  enrollmentId    String     @map("enrollment_id")
  enrollment      Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId        String     @map("lesson_id")
  lesson          Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}

model Payment {
  id              String   @id @default(cuid())
  amount          Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt       DateTime @updatedAt
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  courseId        String   @map("course_id")
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  couponId        String?  @map("coupon_id")
  coupon          Coupon?  @relation(fields: [couponId], references: [id], onDelete: Restrict)
  status          Status
  stripeSessionId String?  @unique @map("stripe_session_id")
  createdAt       DateTime @default(now())

  @@index([userId, couponId, courseId])
  @@map("payments")
}

enum Status {
  pending
  succeeded
  failed
  refunded
}

model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  percentOff Int?      @map("percent_off")
  amountOff  Decimal?  @default(0) @map("amount_off") @db.Decimal(10, 2)
  expiresAt  DateTime?
  maxUses    Int?      @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  payments   Payment[]

  @@index([code])
  @@map("coupons")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?  @db.Text
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String   @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("reviews")
}

model ForumPost {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String?   @map("course_id")
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  comments  Comment[]

  @@index([userId])
  @@index([courseId])
  @@map("forum_posts")
}

model Comment {
  id        String      @id @default(cuid())
  content   String      @db.Text
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?     @map("post_id")
  post      ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  lessonId  String?     @map("lesson_id")
  lesson    Lesson?     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  parentId  String?     @map("parent_id")
  parent    Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  comments  Comment[]   @relation("CommentReplies")
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([postId])
  @@index([lessonId])
  @@index([parentId])
  @@map("comments")
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  courseId  String   @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([courseId])
  @@index([userId])
  @@map("chat_messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}

enum NotificationType {
  enrollment
  payment
  comment_reply
  new_lesson
  system
}

model File {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  type      FileType
  sizeBytes Int      @map("size_bytes")
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("files")
}

enum FileType {
  avatar
  thumbnail
  video
  attachment
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("audit_logs")
}
